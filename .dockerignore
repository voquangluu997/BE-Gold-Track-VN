# .dockerignore
# ============================================
# LOẠI TRỪ CÁC FILE KHÔNG CẦN COPY VÀO DOCKER
# ============================================

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment files
.env
.env.*
!.env.example

# Git
.git/
.gitignore
.gitattributes

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Logs
logs/
*.log
npm-debug.log*

# Build output
dist/
build/
.nyc_output/

# Test coverage
coverage/

# Docker files
Dockerfile*
docker-compose*.yml
.dockerignore

# Temporary files
tmp/
temp/
*.tmp

# OS files
.DS_Store
Thumbs.db

# Prisma
prisma/*.db
prisma/*.db-journal

# Scripts
scripts/

# Documentation
docs/
*.md
!README.md
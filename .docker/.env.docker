# ============================================
# ENVIRONMENT VARIABLES CHO DOCKER
# ============================================

# Application
NODE_ENV=development
APP_PORT=3000
APP_NAME=GoldTrack
APP_URL=http://localhost:3000

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=goldtrack_dev

# Redis
REDIS_PASSWORD=

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Logging
LOG_LEVEL=debug
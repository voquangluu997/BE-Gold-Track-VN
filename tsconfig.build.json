{
  "extends": "./tsconfig.json",
  "include": ["src/**/*"],
  "exclude": ["node_modules", "test", "dist", "**/*spec.ts", "scripts", "scripts/**/*"],
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "src",
    "skipLibCheck": true,
    "noEmitOnError": false, 
    "emitDeclarationOnly": false
  },
}
